// ============================================
// Solar-as-a-Service – Prisma Schema
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Enums ----

enum ProjectStatus {
  PLANNING
  APPROVED
  UNDER_CONSTRUCTION
  COMMISSIONED
  OPERATIONAL
  DECOMMISSIONED
}

enum LegalReviewStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  REQUIRES_CLARIFICATION
}

enum RoofType {
  FLAT
  PITCHED
  SAWTOOTH
  METAL_SHEET
  OTHER
}

// ---- Models ----

/// Gewerbekunde – Firmenkunden mit Dachpachtverträgen
model CommercialClient {
  id            String   @id @default(uuid())
  companyName   String   @map("company_name")
  contactPerson String   @map("contact_person")
  email         String   @unique
  phone         String?
  address       String
  city          String
  postalCode    String   @map("postal_code")
  taxId         String?  @map("tax_id")

  // Relations
  projects SolarProject[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("commercial_clients")
}

/// Solarprojekt – Gewerbliche Dachanlage
model SolarProject {
  id                String        @id @default(uuid())
  projectName       String        @map("project_name")
  status            ProjectStatus @default(PLANNING)
  plannedKwp        Float         @map("planned_kwp")
  estimatedYieldKwh Float?        @map("estimated_yield_kwh")
  roofType          RoofType      @default(OTHER) @map("roof_type")
  roofAreaSqm       Float?        @map("roof_area_sqm")
  plannedStartDate  DateTime?     @map("planned_start_date")
  commissioningDate DateTime?     @map("commissioning_date")

  // Geo-Koordinaten für Kartenansicht
  latitude  Float?
  longitude Float?

  // Relations
  clientId      String         @map("client_id")
  client        CommercialClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  landRegistries LandRegistry[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([status])
  @@map("solar_projects")
}

/// Grundbucheintrag – Rechtliche Prüfung des Grundstücks
model LandRegistry {
  id            String            @id @default(uuid())
  gemarkung     String
  flurstueck    String
  ownerName     String            @map("owner_name")
  ownerAddress  String?           @map("owner_address")
  legalStatus   LegalReviewStatus @default(PENDING) @map("legal_status")
  legalNotes    String?           @map("legal_notes")
  lastCheckedAt DateTime?         @map("last_checked_at")

  // Geo-Koordinaten des Flurstücks
  latitude  Float?
  longitude Float?

  // Relations
  projectId String       @map("project_id")
  project   SolarProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([legalStatus])
  @@map("land_registry")
}

enum UserRole {
  ADMIN
  VIEWER
}

/// Benutzer – Systembenutzer fuer Login
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         UserRole @default(VIEWER)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

